# Server
PORT=
NODE_ENV=
# Comma-separated allowed web origins for Socket.IO CORS in production.
# Example: APP_BASE_URL=https://your-app.azurewebsites.net,https://app.yourdomain.com
APP_BASE_URL=
# Optional: allow non-browser websocket clients without Origin header.
ALLOW_NO_ORIGIN_SOCKET=false

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=1d
READINESS_TIMEOUT_MS=5000

# Database (PostgreSQL)
# App auto-adds these if missing for Postgres in production, but set explicitly if desired.
# PRISMA_CONNECTION_LIMIT=10
# PRISMA_POOL_TIMEOUT=30
# PRISMA_SSL_MODE=require
DATABASE_URL=

# Supabase
# Browser-safe values. The anon key is public by design; RLS protects rows.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only value. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
# Optional explicit auth redirect URL for production.
NEXT_PUBLIC_SITE_URL=

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=patient-documents
AZURE_STORAGE_PUBLIC_BASE_URL=
AZURE_UPLOADS_MODE=azure-only

# Admin invite (optional)
ADMIN_INVITE_CODE=

# AI host (Ollama-compatible endpoint) — optional.
# Leave blank in Azure App Service unless using a separate reachable AI host.
# Example: OLLAMA_BASE_URL=https://your-ollama-host.example.com
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=45000
AI_RATE_LIMIT_PER_MINUTE=40

# Azure Application Insights — optional, auto-enables if set
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# Reminder cron — set to 'true' to auto-dispatch reminders every 5 minutes
# ENABLE_REMINDER_CRON=true
# REMINDER_CRON_INTERVAL_MS=300000
# REMINDER_CRON_BATCH_LIMIT=30

# Logging — debug | info | warn | error (defaults to 'info' in production)
# LOG_LEVEL=info
